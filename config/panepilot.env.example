# Command used to launch the agent inside tmux.
# Examples: claude, codex, openclaw
PANEPILOT_AGENT_CMD="claude"

# Optional environment file sourced before the agent command starts.
# Useful for CLIs that rely on API keys or local runtime config.
PANEPILOT_AGENT_ENV_FILE=""

# Optional shell snippet run after sourcing the env file and before the agent.
PANEPILOT_AGENT_PRELUDE=""

# Shell used when PANEPILOT_AGENT_ENV_FILE or PANEPILOT_AGENT_PRELUDE is set.
PANEPILOT_AGENT_SHELL="bash"

# Working directory for the agent session.
PANEPILOT_WORK_DIR="$HOME"

# Name of the tmux session.
PANEPILOT_SESSION="panepilot"

# Where logs and keepalive state are written.
PANEPILOT_LOG_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/panepilot"

# Optional task file consumed by scripts/tasks/nightly.sh.
PANEPILOT_TASK_FILE="$HOME/tasks/nightly.md"

# How often keepalive should send the compact command, in seconds.
PANEPILOT_COMPACT_INTERVAL_SECONDS="21600"

# Command used to compact or summarize context.
PANEPILOT_COMPACT_COMMAND="/compact"

# Message sent after an automatic restart.
PANEPILOT_RECOVERY_MESSAGE="The session was restarted. Resume the previous task and summarize any missing context first."

# Default number of lines shown by `./bin/panepilot capture`.
PANEPILOT_CAPTURE_LINES="120"
