PANEPILOT_AGENT_CMD="openclaw tui --session panepilot"
PANEPILOT_PROCESS_REGEX="^openclaw$"
PANEPILOT_READY_REGEX="openclaw tui -|gateway connected"
PANEPILOT_WORK_DIR="$HOME/work/my-project"
PANEPILOT_SESSION="panepilot-openclaw"
PANEPILOT_LOG_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/panepilot"
PANEPILOT_TASK_FILE="$HOME/work/my-project/tasks/nightly.md"
